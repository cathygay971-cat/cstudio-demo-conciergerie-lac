# ─── Resend (emails transactionnels) ────────────────────────────────────────
# Obtenir une clé sur https://resend.com → Settings → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse qui REÇOIT les leads (boîte du client ou de l'agence)
RESEND_TO_EMAIL=contact@votreclient.fr

# Adresse expéditrice vérifiée dans Resend (domaine du client configuré)
RESEND_FROM_EMAIL=noreply@votreclient.fr
